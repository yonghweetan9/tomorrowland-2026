# ── Tomorrowland 2026 Companion · environment variables ──
# Copy this file to ".env" and fill in real values. NEVER commit ".env".

# Supabase Project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anon / publishable key (Project Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=

# Supabase service_role / secret key — USED ONLY by scripts/seed-lineup.mjs on your machine.
# Never expose this to the client and never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ExchangeRate access key (https://exchangerate.host → free API access key)
VITE_EXCHANGERATE_API_KEY=
